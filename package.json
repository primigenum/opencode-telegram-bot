{
  "name": "@primigenum/opencode-telegram-bot",
  "version": "0.21.2",
  "description": "Telegram bot client for OpenCode to run and monitor coding tasks from chat. Bun port of @grinev/opencode-telegram-bot.",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "opencode-telegram": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts"
  },
  "imports": {
    "#vitest": "./tests/helpers/vitest-shim.ts",
    "#src/*": "./src/*",
    "#tests/*": "./tests/*",
    "#helpers/*": "./tests/helpers/*"
  },
  "files": [
    "src",
    "bunfig.toml",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir dist --target bun --format esm && bun build ./src/index.ts --outdir dist --target bun --format esm",
    "start": "bun run dist/cli.js",
    "dev": "bun --hot run src/cli.ts start",
    "dev:index": "bun --hot run src/index.ts",
    "start:foreground": "bun run src/cli.ts start",
    "release:prepare": "bun run scripts/release-prepare.mjs",
    "release:rc": "bun run scripts/release-prepare.mjs rc",
    "release:notes:preview": "bun run scripts/release-notes-preview.mjs",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "check": "bun run lint && bun run build && bun test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/primigenum/opencode-telegram-bot.git"
  },
  "keywords": [
    "opencode",
    "telegram",
    "telegram-bot",
    "grammy",
    "developer-tools",
    "cli",
    "bun"
  ],
  "author": "primigenum",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/primigenum/opencode-telegram-bot/issues"
  },
  "homepage": "https://github.com/primigenum/opencode-telegram-bot#readme",
  "dependencies": {
    "@google-cloud/text-to-speech": "^6.4.0",
    "@grammyjs/menu": "^1.3.1",
    "@opencode-ai/sdk": "^1.1.21",
    "dotenv": "^17.2.3",
    "grammy": "^1.39.2",
    "https-proxy-agent": "^7.0.6",
    "mdast-util-to-string": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "socks-proxy-agent": "^8.0.5",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.0.8",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.0",
    "typescript": "^5.9.3"
  }
}
